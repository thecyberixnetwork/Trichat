#define LIBWOLFSSL_CONFIGURE_ARGS " '--enable-static' '--disable-shared' '--enable-tls13' '--enable-sni' '--enable-curve25519' '--enable-ed25519' '--enable-dtls' '--enable-srtp' '--enable-certgen' '--enable-keygen' '--enable-opensslextra' 'CFLAGS=-Os -fPIC' 'CC=gcc'"
#define LIBWOLFSSL_GLOBAL_CFLAGS "  -DHAVE_LIMITS_H=1 -DWOLFSSL_HAVE_ATOMIC_H -DWOLFSSL_HAVE_ASSERT_H  -Os -fPIC   -Wno-pragmas -Wall -Wextra -Wunknown-pragmas --param=ssp-buffer-size=1 -Waddress -Warray-bounds -Wbad-function-cast -Wchar-subscripts -Wcomment -Wfloat-equal -Wformat-security -Wformat=2 -Wmaybe-uninitialized -Wmissing-field-initializers -Wmissing-noreturn -Wmissing-prototypes -Wnested-externs -Wnormalized=id -Woverride-init -Wpointer-arith -Wpointer-sign -Wshadow -Wsign-compare -Wstrict-overflow=1 -Wstrict-prototypes -Wswitch-enum -Wundef -Wunused -Wunused-result -Wunused-variable -Wwrite-strings -fwrapv  -fvisibility=hidden -DHAVE_C___ATOMIC=1 -DHAVE_THREAD_LS -DNDEBUG -DNO_DO178 -DWOLFSSL_X86_64_BUILD -DWOLFSSL_ASN_TEMPLATE -pthread -DWOLFSSL_DTLS -DERROR_QUEUE_PER_THREAD -DTFM_TIMING_RESISTANT -DECC_TIMING_RESISTANT -DWC_RSA_BLINDING -DWOLFSSL_ARMASM_NO_HW_CRYPTO -DWOLFSSL_USE_ALIGN -DWOLFSSL_SHA224 -DWOLFSSL_SHA512 -DWOLFSSL_SHA384 -DHAVE_HKDF -DNO_DSA -DHAVE_ECC -DECC_SHAMIR -DECC_MIN_KEY_SZ=224 -DNO_OLD_TLS -DWC_RSA_PSS -DWOLFSSL_PSS_LONG_SALT -DWOLFSSL_ASN_PRINT -DWOLFSSL_BASE64_ENCODE -DWC_SRTP_KDF -DHAVE_AES_ECB -DWOLFSSL_AES_DIRECT -DWOLFSSL_SHA3 -DWOLFSSL_SHAKE128 -DWOLFSSL_SHAKE256 -DWOLFSSL_HAVE_MLKEM -DWOLFSSL_TLS_NO_MLKEM_STANDALONE -DWOLFSSL_PQC_HYBRIDS -DHAVE_POLY1305 -DHAVE_CHACHA -DHAVE_HASHDRBG -DWOLFSSL_DRBG_SHA512 -DHAVE_TLS_EXTENSIONS -DHAVE_SNI -DHAVE_KEYING_MATERIAL -DHAVE_TLS_EXTENSIONS -DHAVE_SUPPORTED_CURVES -DHAVE_FFDHE_2048 -DHAVE_SUPPORTED_CURVES -DWOLFSSL_TLS13 -DHAVE_TLS_EXTENSIONS -DHAVE_EXTENDED_MASTER -DNO_RC4 -DHAVE_ENCRYPT_THEN_MAC -DNO_PSK -DNO_MD4 -DWOLFSSL_ENCRYPTED_KEYS -DWOLFSSL_SP_MATH_ALL -DWOLFSSL_SP_X86_64 -DWC_NO_ASYNC_THREADING -DHAVE_DH_DEFAULT_PARAMS -DHAVE_CURVE25519 -DHAVE_ED25519 -DWOLFSSL_SYS_CA_CERTS -DWOLFSSL_KEY_GEN -DWOLFSSL_CERT_GEN -DOPENSSL_EXTRA -DNO_DES3 -DNO_DES3_TLS_SUITES -DGCM_TABLE_4BIT -DHAVE_AESGCM -DWOLFSSL_SRTP -DHAVE_TLS_EXTENSIONS -DHAVE_SERVER_RENEGOTIATION_INFO -Wall -Wno-unused -O2  -DHAVE___UINT128_T=1 -DHAVE_GETPID=1 -DWOLFSSL_TEST_STATIC_BUILD -DHAVE_WC_INTROSPECTION -include ./.build_params " LIBWOLFSSL_GLOBAL_EXTRA_CFLAGS
